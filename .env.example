# ============================================
# Pixelle-Video Production Environment Config
# ============================================
# Copy this file to .env and fill in your values
#   cp .env.example .env
# Then start services:
#   docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d

# ==================== Domain ====================
# Your domain name (required for HTTPS)
DOMAIN=pixelle.example.com

# Your email for Let's Encrypt SSL certificate notifications
SSL_EMAIL=admin@example.com

# ==================== China Mirror ====================
# Set to true if deploying from China (uses mirror sources)
USE_CN_MIRROR=false

# ==================== MySQL Database ====================
# Database credentials (used for user authentication)
MYSQL_ROOT_PASSWORD=change_me_strong_password
MYSQL_DATABASE=pixelle_video
MYSQL_USER=pixelle
MYSQL_PASSWORD=change_me_user_password

# ==================== API Config ====================
# LLM API (for content generation)
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max

# RunningHub (for video/image generation workflows)
RUNNINGHUB_API_KEY=your_runninghub_api_key

# TTS (optional, Edge TTS is used by default)
# TTS_PROVIDER=volc
# VOLC_ACCESS_KEY=your_volc_access_key
# VOLC_SECRET_KEY=your_volc_secret_key

# ==================== Timezone ====================
TZ=Asia/Shanghai